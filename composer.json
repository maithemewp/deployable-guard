{
    "name": "bizbudding/deployable-guard",
    "description": "Verify a committed composer autoloader is deployable as a raw git tree; self-installs a pre-commit hook + CI check.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10 || ^11 || ^12"
    },
    "autoload": {
        "psr-4": {
            "Bizbudding\\DeployableGuard\\": "src/"
        }
    },
    "bin": [
        "bin/deployable-guard"
    ],
    "scripts": {
        "test": "phpunit"
    }
}
